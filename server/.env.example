# Tripo3D API Key (get from https://platform.tripo3d.ai)
# Keys start with tsk_
TRIPO_API_KEY=tsk_your_api_key_here

# Hugging Face token for HY-Motion 1.0 (get from https://huggingface.co/settings/tokens)
# If set, users don't need to paste it in the UI.
HF_TOKEN=hf_your_token_here

# Server port
PORT=3001
